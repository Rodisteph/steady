          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Vincula este hábito a Salud (pasos, distancia, agua, meditación, ejercicio, calorías): se validará automáticamente al alcanzar tu objetivo del día."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
