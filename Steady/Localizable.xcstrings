    "Tu as franchi %lld validations au total. Quel chemin parcouru !" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You've passed %lld total completions. What a journey!"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Has superado %lld validaciones en total. ¡Qué camino!"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Já passaste %lld validações no total. Que caminho!"
          }
        }
      }
    },
    "Tu as pris le temps d'écrire ce soir — déjà une belle habitude." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You took time to write tonight — already a great habit."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Te tomaste tiempo para escribir esta noche — ya es un buen hábito."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tiraste tempo para escrever hoje — já é um bom hábito."
          }
        }
      }
    },
    "Tu as validé %lld fois cette semaine. Chaque petit pas compte !" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You logged it %lld times this week. Every little step counts!"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lo has registrado %lld veces esta semana. ¡Cada pequeño paso cuenta!"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Registaste %lld vezes esta semana. Cada pequeno passo conta!"
          }
        }
      }
    },
    "Tu avais %lld jours d'affilée. Protège la journée d'hier pour la faire repartir — elle comptera comme un jour de repos." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You had %lld days in a row. Protect yesterday to bring it back — it will count as a rest day."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Llevabas %lld días seguidos. Protege el día de ayer para recuperarla: contará como un día de descanso."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você tinha %lld dias seguidos. Proteja o dia de ontem para recuperá-la — ele contará como um dia de descanso."
          }
        }
      }
    },
    "Tu enchaînes « %@ » depuis %lld jours. Solide." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You've kept « %@ » going for %lld days. Solid."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Llevas « %@ » %lld días seguidos. Sólido."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Tu enchaînes « %1$@ » depuis %2$lld jours. Solide."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Manténs « %@ » há %lld dias. Sólido."
          }
        }
      }
    },
    "Tu fais déjà mieux que le toi d'il y a un mois. Maintenant, vise celui du mois prochain." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You're already beating the you from a month ago. Now aim for next month's."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ya superas al tú de hace un mes. Ahora apunta al del mes que viene."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você já supera o você de um mês atrás. Agora mire no do mês que vem."
          }
        }
      }
    },
    "Tu n'as jamais validé « %@ » depuis %lld jours. La retirer allégerait ta liste." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You've never completed « %@ » in %lld days. Removing it would lighten your list."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nunca completaste « %@ » en %lld días. Quitarlo aligeraría tu lista."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Tu n'as jamais validé « %1$@ » depuis %2$lld jours. La retirer allégerait ta liste."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nunca validaste « %@ » em %lld dias. Removê-lo aliviaria a tua lista."
          }
        }
      }
    },
    "Tu n'as pas besoin d'être parfait, juste régulier. Un petit pas suffit." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You don't need to be perfect, just consistent. One small step is enough."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No necesitas ser perfecto, solo constante. Un pequeño paso basta."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Não precisas de ser perfeito, apenas constante. Um pequeno passo basta."
          }
        }
      }
    },
    "Tu ne rates presque jamais le %@. Ton point fort." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You almost never miss %@. Your strength."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Casi nunca fallas el %@. Tu punto fuerte."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quase nunca falhas %@. O teu ponto forte."
          }
        }
      }
    },
    "Tu progresses : +%lld points vs le mois dernier." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You're progressing: +%lld points vs last month."
