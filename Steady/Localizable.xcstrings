    "Belle semaine : %lld%% de réussite et une série de %lld jours. Vise un petit effort le %@.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Nice week: %lld%% success and a %lld-day streak. Aim for a small effort on %@."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Buena semana: %lld%% de logro y una racha de %lld días. Haz un pequeño esfuerzo el %@."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "Belle semaine : %1$lld%% de réussite et une série de %2$lld jours. Vise un petit effort le %3$@."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Boa semana: %lld%% de sucesso e uma sequência de %lld dias. Faz um pequeno esforço na %@."
          }
        }
