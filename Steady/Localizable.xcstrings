    "%lld jours. Officiellement inarrêtable. Officieusement : on veut voir jusqu'où ça monte.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld days. Officially unstoppable. Unofficially: we want to see how high this goes."
