      }
    },
    "C'est le nom que tes amis chercheront pour t'ajouter. Sans pseudo, tu apparais comme « Moi »." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This is the name your friends will search for to add you. Without it, you show up as “Me”."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es el nombre que tus amigos buscarán para añadirte. Sin apodo, apareces como «Yo»."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "É o nome que seus amigos buscarão para adicionar você. Sem apelido, você aparece como “Eu”."
          }
        }
      }
    },
