    },
    "Lie cette habitude à Santé (pas, distance, eau, méditation, exercice, calories) : elle se validera automatiquement quand ton objectif du jour est atteint.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
