          "stringUnit" : {
            "state" : "translated",
            "value" : "Estás a progredir: +%lld pontos vs o mês passado."
          }
        }
      }
    },
    "Tu réussis « %@ » surtout vers %lldh. Déplace son rappel à cette heure." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You complete « %@ » mostly around %lld:00. Move its reminder there."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
