          "stringUnit": {
            "state": "translated",
            "value": "Costumas parar após cerca de %lld dias. Antecipa esse momento, com calma."
          }
        }
      }
    },
    "Tu te sens nettement mieux les jours où tu valides tes habitudes. 💚": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You feel noticeably better on days you complete your habits. 💚"
