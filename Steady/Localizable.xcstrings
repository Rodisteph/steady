    "Ta série prend de l'élan. Ce serait dommage de la lâcher juste avant que ça devienne intéressant.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your streak is picking up speed. Shame to drop it right before it gets interesting."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu racha está cogiendo impulso. Sería una pena soltarla justo antes de que se ponga interesante."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Sua sequência está ganhando embalo. Seria uma pena largá-la bem antes de ficar interessante."
          }
        }
