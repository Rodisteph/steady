    "Superbe semaine ! Tu as validé %lld%% de tes habitudes et tenu une série de %lld jours. %@ reste ton jour à surveiller.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Great week! You completed %lld%% of your habits and held a %lld-day streak. %@ remains your day to watch."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¡Gran semana! Completaste el %lld%% de tus hábitos y mantuviste una racha de %lld días. El %@ sigue siendo tu día a vigilar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "new",
            "value": "Superbe semaine ! Tu as validé %1$lld%% de tes habitudes et tenu une série de %2$lld jours. %3$@ reste ton jour à surveiller."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ótima semana! Validaste %lld%% dos teus hábitos e manténs uma sequência de %lld dias. %@ continua a ser o teu dia a vigiar."
          }
        }
      }
    },
