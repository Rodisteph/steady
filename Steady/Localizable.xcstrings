      }
    },
    "Tu t'arrêtes souvent après environ %lld jours. Anticipe ce cap, en douceur.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You often stop after about %lld days. Anticipate that point, gently."
