    "« %@ » : %lld jours d'affilée. Continue ! 🔥" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%1$@\": %2$lld days in a row. Keep going! 🔥"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«%1$@»: %2$lld días seguidos. ¡Sigue! 🔥"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "« %1$@ » : %2$lld jours d'affilée. Continue ! 🔥"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«%1$@»: %2$lld dias seguidos. Continua! 🔥"
          }
        }
      }
    },
    "« %@ » (objectif %lld) est souvent manquée. Réduis l'objectif pour reprendre l'élan." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "« %@ » (goal %lld) is often missed. Lower the goal to regain momentum."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "« %@ » (objetivo %lld) se incumple a menudo. Baja el objetivo para recuperar el ritmo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "« %1$@ » (objectif %2$lld) est souvent manquée. Réduis l'objectif pour reprendre l'élan."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "« %@ » (objetivo %lld) falha muitas vezes. Reduz o objetivo para retomar o ritmo."
          }
        }
      }
    },
    "« %@ » est la plus dure pour toi. Commence par une version mini, juste pour garder l'élan." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" is the hardest for you. Start with a mini version, just to keep momentum."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«%@» es el más difícil para ti. Empieza con una versión mini, solo para mantener el impulso."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«%@» é o mais difícil para ti. Começa por uma versão mini, só para manter o ritmo."
          }
        }
      }
    },
    "« %@ » est ton habitude la plus solide." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "« %@ » is your strongest habit."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "« %@ » es tu hábito más sólido."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "« %@ » é o teu hábito mais sólido."
          }
        }
      }
    },
    "« %@ » te résiste. Essaie de la déplacer vers %lldh, ton heure la plus efficace." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%1$@\" is giving you trouble. Try moving it to %2$lld:00, your most effective time."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«%1$@» se te resiste. Prueba a moverlo a las %2$lld:00, tu hora más eficaz."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "« %1$@ » te résiste. Essaie de la déplacer vers %2$lldh, ton heure la plus efficace."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«%1$@» está a custar-te. Tenta movê-lo para as %2$lld:00, a tua hora mais eficaz."
          }
        }
      }
    },
    "« %@ » te résiste. Réduis-la à 2 minutes et gagne le bras de fer." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” is fighting back. Shrink it to 2 minutes and win the arm wrestle."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«%@» se te resiste. Redúcelo a 2 minutos y gana el pulso."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” está resistindo. Reduza para 2 minutos e vença a queda de braço."
          }
        }
      }
    },
