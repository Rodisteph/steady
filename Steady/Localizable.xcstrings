    "%lld jours d'affilée. Le cap des 7, c'est maintenant que ça se joue.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld days in a row. The 7-day mark is decided right now."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld días seguidos. La marca de los 7 se juega ahora mismo."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld dias seguidos. A marca dos 7 se decide agora."
          }
        }
      }
    },
    "%lld jours d'affilée. À ce niveau, ce n'est plus une habitude, c'est un mode de vie.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld days in a row. At this point it's not a habit anymore, it's a lifestyle."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld días seguidos. A este nivel ya no es un hábito, es un estilo de vida."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld dias seguidos. Nesse nível já não é um hábito, é um estilo de vida."
          }
        }
      }
    },
